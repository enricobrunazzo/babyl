# URL del signaling server WebSocket. Se vuoto il client usa /ws sullo stesso
# host della pagina (proxy Vite in dev, reverse proxy in produzione).
VITE_SIGNALING_URL=

# ICE server WebRTC come array JSON. Se vuoto usa solo STUN pubblico.
# In produzione aggiungere un TURN server per i NAT restrittivi, es.:
# VITE_ICE_SERVERS=[{"urls":"turn:turn.babyl.it:3478","username":"u","credential":"c"}]
VITE_ICE_SERVERS=
